{
  "name": "postgresql-ssh-tunnels-dashboard",
  "private": true,
  "version": "1.0.0",
  "description": "Elegant corporate administration client to configure, monitor, and query PostgreSQL databases securely over SSH tunnels.",
  "author": "Duneon <support+postgresqlsshdashboard@duneon.dev>",
  "homepage": "https://duneon.dev",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "build:desktop": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs && electron-builder --linux deb"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pg": "^8.21.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.8.1",
    "ssh2": "^1.17.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.20.0",
    "@types/ssh2": "^1.15.5",
    "autoprefixer": "^10.4.21",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  },
  "build": {
    "appId": "dev.duneon.postgresqlsshdashboard",
    "productName": "Duneon Postgres SSH Dashboard",
    "npmRebuild": false,
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "dist/**/*",
      "public/**/*",
      "electron-main.cjs",
      "package.json"
    ],
    "linux": {
      "target": [
        "deb"
      ],
      "category": "Development",
      "icon": "public/logo_no_text.svg"
    }
  }
}
